# visit https://giscus.app to get your Giscus ids
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
NEXT_PUBLIC_UTTERANCES_REPO=
NEXT_PUBLIC_DISQUS_SHORTNAME=


MAILCHIMP_API_KEY=
MAILCHIMP_API_SERVER=
MAILCHIMP_AUDIENCE_ID=

BUTTONDOWN_API_KEY=

CONVERTKIT_API_KEY=
# curl https://api.convertkit.com/v3/forms?api_key=<your_public_api_key> to get your form ID
CONVERTKIT_FORM_ID=

KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

REVUE_API_KEY=

EMAILOCTOPUS_API_KEY=
EMAILOCTOPUS_LIST_ID=

NEXT_PUBLIC_GOOGLE_ADS_CLIENT_ID=

# DB — Neon(Vercel 마켓플레이스 연동이 주입). 런타임은 풀링 URL, 마이그레이션은 UNPOOLED.
RNC_DATABASE_URL=
RNC_DATABASE_URL_UNPOOLED=

# 조회수·반응·투표 쓰기 버퍼(Upstash Redis, REST). 미설정이면 기존처럼 Postgres 에 직접 쓴다 —
# 기능은 그대로 동작하고 Neon wake 절감만 사라진다.
#
# Vercel 마켓플레이스로 Upstash 를 연동하면 KV_REST_API_URL / KV_REST_API_TOKEN 이 자동 주입되고
# lib/redis.ts 가 그 이름도 읽는다 → 그 경우 아래 두 줄은 비워두면 된다(값 복제 금지).
# 쓰면 안 되는 것: KV_REST_API_READ_ONLY_TOKEN(쓰기 거부 → 조용히 폴백), KV_URL/REDIS_URL(TCP용).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel Cron 이 /api/cron/flush 호출 시 붙이는 Bearer 토큰. 미설정이면 인증을 건너뛴다(권장하지 않음).
CRON_SECRET=

# AI — 서버 전용(클라이언트 노출 금지). 에세이 BYOAI 는 OPENAI_MODEL, 안내 챗봇은 CHAT_MODEL 사용.
OPENAI_API_KEY=
CHAT_MODEL=
# 예) CHAT_MODEL=gpt-5.4-mini (사이트 안내 챗봇 기본 — 미설정 시 코드 기본값 gpt-5.4-mini)
